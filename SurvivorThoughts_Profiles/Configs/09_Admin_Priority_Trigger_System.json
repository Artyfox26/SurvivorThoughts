    "MedicalTreatmentMessages": [
        "Hold still. This might keep me alive.",
        "Clean hands, steady breath, then the wound.",
        "Pain means I am still here.",
        "Patch it now or pay for it later.",
        "Medicine only matters if I survive long enough.",
        "One more treatment. One more chance."
    ],
    "BloodDiscoveryMessages": [
        "So that is my blood. Useful, if I live.",
        "My blood has a name now.",
        "Good to know before I bleed out.",
        "That little test might save me one day.",
        "Information is another kind of supply.",
        "Remember the type. Forgetting could kill me."
    ],
    "FireAndShelterMessages": [
        "Warmth makes the world feel less dead.",
        "Smoke can be seen, but cold kills quieter.",
        "A roof and a flame. Almost civilization.",
        "Stay close to the heat, but watch the dark.",
        "This place might hold for a few minutes.",
        "The fire sounds too loud in the silence."
    ],
    "WeaponStateMessages": [
        "Check the weapon. It only matters if it works.",
        "A jam at the wrong time is a death sentence.",
        "Metal, oil, and luck.",
        "Keep it clean. Keep it close.",
        "The weapon feels heavier when I need it.",
        "One bad click and everything changes."
    ],
    "AmmoStressMessages": [
        "Count what is left. Then count it again.",
        "Every round has to matter now.",
        "Empty magazines make loud promises.",
        "Do not waste the last one.",
        "The quiet after the last shot is worse.",
        "A handful of rounds is not safety."
    ],
    "VehicleMessages": [
        "Engines draw attention. So does walking.",
        "If this thing dies out here, I walk.",
        "Wheels mean distance. Distance means time.",
        "The noise will carry.",
        "Check it twice before trusting it.",
        "A running engine feels like hope and bait."
    ],
    "BaseRaidMessages": [
        "Walls only slow people down.",
        "Every lock is an invitation to someone.",
        "This place is safe until someone wants it.",
        "Wood, metal, and false confidence.",
        "Hide what matters. Reinforce what shows.",
        "A base is just a promise to defend something."
    ],
    "HuntingFishingMessages": [
        "Food with blood still warm.",
        "Waste nothing. Not anymore.",
        "The land still gives, if I know where to look.",
        "Scales, hide, bone, meat. Survival has parts.",
        "The quiet work keeps me alive.",
        "Another meal bought with patience."
    ],
    "CraftingMessages": [
        "Make do. That is the rule now.",
        "Broken things can still be useful.",
        "My hands remember more than I do.",
        "Small repairs keep death delayed.",
        "Nothing is junk until I cannot use it.",
        "Improvised does not mean useless."
    ],
    "HandsHygieneMessages": [
        "My hands need cleaning before they kill me.",
        "Blood under the nails. Not all of it mine.",
        "Clean hands, cleaner food, better odds.",
        "I should wash this off before I forget.",
        "The smell stays longer than it should.",
        "Dirt is one thing. Blood is another."
    ],
    "GasMaskFilterMessages": [
        "The filter will not last forever.",
        "Every breath has a timer.",
        "The mask makes me sound alone.",
        "If the seal fails, I am done.",
        "Do not trust clean air in a dead zone.",
        "Breathe slow. Count the filter."
    ],
    "BetrayalTrustMessages": [
        "Trust is heavier after it breaks.",
        "I remember what they did.",
        "A friendly voice can still hide a knife.",
        "Debt, mercy, betrayal. It all stays with me.",
        "Some faces are warnings now.",
        "People are the hardest weather to read."
    ]
}